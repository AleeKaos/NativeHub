<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.nativehub">

    <!-- Permissões de Rede -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />

    <!-- Permissões de Localização -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Permissões de Mídia -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Permissões de Armazenamento -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <application
        android:name=".NativeHubApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="NativeHub"
        android:theme="@style/Theme.NativeHub">

        <!-- MainActivity: Tela inicial (processo padrão do app) -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- Abas 1 a 15: cada uma em seu próprio processo (:tabN), garantindo
             cookies, cache, LocalStorage e sessão independentes por aba. -->

        <!-- EightUActivity: Aba 1 -->
        <activity
            android:name=".EightUActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:process=":tab1" />

        <!-- GenericTabActivity: Aba 2 -->
        <activity
            android:name=".GenericTabActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:process=":tab2" />

        <!-- Abas 3 a 15: subclasses finas de GenericTabActivity, uma por processo -->
        <activity
            android:name=".Tab3Activity"
            android:exported="false"
            android:launchMode="singleTask"
            android:process=":tab3" />

        <activity
            android:name=".Tab4Activity"
            android:exported="false"
            android:launchMode="singleTask"
            android:process=":tab4" />

        <activity
            android:name=".Tab5Activity"
            android:exported="false"
            android:launchMode="singleTask"
            android:process=":tab5" />

        <activity
            android:name=".Tab6Activity"
            android:exported="false"
            android:launchMode="singleTask"
            android:process=":tab6" />

        <activity
            android:name=".Tab7Activity"
            android:exported="false"
            android:launchMode="singleTask"
            android:process=":tab7" />

        <activity
            android:name=".Tab8Activity"
            android:exported="false"
            android:launchMode="singleTask"
            android:process=":tab8" />

        <activity
            android:name=".Tab9Activity"
            android:exported="false"
            android:launchMode="singleTask"
            android:process=":tab9" />

        <activity
            android:name=".Tab10Activity"
            android:exported="false"
            android:launchMode="singleTask"
            android:process=":tab10" />

        <activity
            android:name=".Tab11Activity"
            android:exported="false"
            android:launchMode="singleTask"
            android:process=":tab11" />

        <activity
            android:name=".Tab12Activity"
            android:exported="false"
            android:launchMode="singleTask"
            android:process=":tab12" />

        <activity
            android:name=".Tab13Activity"
            android:exported="false"
            android:launchMode="singleTask"
            android:process=":tab13" />

        <activity
            android:name=".Tab14Activity"
            android:exported="false"
            android:launchMode="singleTask"
            android:process=":tab14" />

        <activity
            android:name=".Tab15Activity"
            android:exported="false"
            android:launchMode="singleTask"
            android:process=":tab15" />

        <!-- Settings Activities -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="Configurações" />

        <activity
            android:name=".SiteSettingsActivity"
            android:exported="false"
            android:label="Abas do Site" />

    </application>

</manifest>
'