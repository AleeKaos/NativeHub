<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.nativehub">

    <!-- Permissões de Rede -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />

    <!-- Permissões de Localização -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Permissões de Mídia -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Permissões de Armazenamento -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="NativeHub"
        android:theme="@style/Theme.NativeHub">

        <!-- MainActivity: Tela inicial -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- EightUActivity: Aba 1 (processo principal) -->
        <activity
            android:name=".EightUActivity"
            android:exported="false"
            android:launchMode="singleTask" />

        <!-- GenericTabActivity: Reutilizável para múltiplos processos -->
        <activity
            android:name=".GenericTabActivity"
            android:exported="false"
            android:launchMode="singleTask" />

        <!-- Settings Activities -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="Configurações" />

        <activity
            android:name=".SiteSettingsActivity"
            android:exported="false"
            android:label="Abas do Site" />

    </application>

</manifest>
